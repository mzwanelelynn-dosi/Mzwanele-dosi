  <style>
    *, *::before, *::after { margin: 0; padding: 0; box-sizing: border-box; }

    :root {
      --cream: #f5efe6;
      --cream-dark: #ede3d4;
      --brown-light: #c9a87c;
      --brown: #8b6340;
      --brown-dark: #5c3d1e;
      --espresso: #2e1a0e;
      --text: #3a2410;
      --text-muted: #7a5c3e;
      --white: #fdfaf6;
    }

    html { scroll-behavior: smooth; }

    body {
      font-family: 'DM Sans', sans-serif;
      background: var(--cream);
      color: var(--text);
      overflow-x: hidden;
    }

    /* NAV */
    nav {
      position: fixed; top: 0; left: 0; right: 0; z-index: 100;
      background: rgba(245,239,230,0.92);
      backdrop-filter: blur(10px);
      border-bottom: 1px solid var(--cream-dark);
      padding: 0 2rem;
      height: 64px;
      display: flex; align-items: center; justify-content: space-between;
    }
    .nav-logo {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.3rem; font-weight: 600;
      color: var(--brown-dark);
      letter-spacing: 0.04em;
    }
    .nav-links { display: flex; gap: 2rem; list-style: none; }
    .nav-links a {
      text-decoration: none; font-size: 0.82rem;
      color: var(--text-muted); font-weight: 500;
      letter-spacing: 0.06em; text-transform: uppercase;
      transition: color 0.2s;
    }
    .nav-links a:hover { color: var(--brown); }

    /* HERO */
    .hero {
      min-height: 100vh;
      display: flex; align-items: center; justify-content: center;
      padding: 100px 2rem 4rem;
      background: linear-gradient(160deg, var(--cream) 55%, var(--cream-dark) 100%);
      position: relative; overflow: hidden;
    }
    .hero::before {
      content: 'MD';
      position: absolute; right: -2rem; top: 50%;
      transform: translateY(-50%);
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(180px, 28vw, 380px);
      font-weight: 700; color: rgba(139,99,64,0.06);
      line-height: 1; user-select: none; pointer-events: none;
    }
    .hero-inner {
      max-width: 820px; width: 100%;
      animation: fadeUp 0.9s ease both;
    }
    .hero-tag {
      display: inline-block;
      background: var(--brown-light);
      color: var(--white);
      font-size: 0.72rem; letter-spacing: 0.14em;
      text-transform: uppercase; font-weight: 500;
      padding: 0.35rem 1rem; border-radius: 2rem;
      margin-bottom: 1.5rem;
    }
    .hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 7vw, 5.5rem);
      font-weight: 600; line-height: 1.05;
      color: var(--espresso);
      margin-bottom: 0.6rem;
    }
    .hero-subtitle {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.1rem, 2.5vw, 1.5rem);
      color: var(--brown); font-weight: 400;
      margin-bottom: 1.8rem;
      letter-spacing: 0.02em;
    }
    .hero-tagline {
      font-size: 1rem; color: var(--text-muted);
      line-height: 1.7; max-width: 560px;
      margin-bottom: 2.5rem; font-weight: 300;
    }
    .hero-stats {
      display: flex; gap: 2.5rem; flex-wrap: wrap;
      margin-bottom: 2.5rem;
    }
    .stat-item { text-align: left; }
    .stat-num {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.4rem; font-weight: 700;
      color: var(--brown-dark); line-height: 1;
    }
    .stat-label {
      font-size: 0.75rem; color: var(--text-muted);
      letter-spacing: 0.06em; text-transform: uppercase;
      margin-top: 0.2rem;
    }
    .hero-cta { display: flex; gap: 1rem; flex-wrap: wrap; }
    .btn {
      display: inline-block; padding: 0.8rem 1.8rem;
      border-radius: 2rem; font-size: 0.85rem;
      font-weight: 500; text-decoration: none;
      letter-spacing: 0.04em; transition: all 0.25s;
      cursor: pointer; border: none;
    }
    .btn-primary {
      background: var(--brown-dark); color: var(--white);
    }
    .btn-primary:hover { background: var(--espresso); transform: translateY(-2px); }
    .btn-outline {
      background: transparent; color: var(--brown-dark);
      border: 1.5px solid var(--brown-dark);
    }
    .btn-outline:hover { background: var(--brown-dark); color: var(--white); transform: translateY(-2px); }

    /* SECTIONS */
    section { padding: 5rem 2rem; }
    .section-inner { max-width: 900px; margin: 0 auto; }
    .section-label {
      font-size: 0.72rem; letter-spacing: 0.18em; text-transform: uppercase;
      color: var(--brown-light); font-weight: 500; margin-bottom: 0.5rem;
    }
    .section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2rem, 4vw, 3rem);
      font-weight: 600; color: var(--espresso);
      margin-bottom: 2.5rem; line-height: 1.1;
    }

    /* ABOUT */
    #about { background: var(--white); }
    .about-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 3rem; align-items: start; }
    .about-text p {
      font-size: 0.97rem; line-height: 1.85;
      color: var(--text-muted); margin-bottom: 1rem;
    }
    .about-highlights { display: flex; flex-direction: column; gap: 1rem; }
    .highlight-card {
      background: var(--cream);
      border-left: 3px solid var(--brown-light);
      padding: 1rem 1.2rem; border-radius: 0 8px 8px 0;
    }
    .highlight-card strong {
      display: block; font-size: 0.85rem; font-weight: 600;
      color: var(--brown-dark); margin-bottom: 0.2rem;
    }
    .highlight-card span { font-size: 0.82rem; color: var(--text-muted); }

    /* SKILLS */
    #skills { background: var(--cream); }
    .skills-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(220px, 1fr)); gap: 1rem; }
    .skill-tag {
      background: var(--white);
      border: 1px solid var(--cream-dark);
      padding: 0.7rem 1rem;
      border-radius: 8px;
      font-size: 0.82rem; color: var(--text);
      font-weight: 400; transition: all 0.2s;
      display: flex; align-items: center; gap: 0.5rem;
    }
    .skill-tag:hover { border-color: var(--brown-light); background: var(--cream-dark); }
    .skill-dot { width: 6px; height: 6px; border-radius: 50%; background: var(--brown-light); flex-shrink: 0; }

    /* EXPERIENCE */
    #experience { background: var(--white); }
    .timeline { position: relative; }
    .timeline::before {
      content: ''; position: absolute; left: 0; top: 0; bottom: 0;
      width: 2px; background: var(--cream-dark);
    }
    .timeline-item {
      padding-left: 2rem; margin-bottom: 3rem; position: relative;
      animation: fadeUp 0.6s ease both;
    }
    .timeline-item::before {
      content: ''; position: absolute; left: -5px; top: 6px;
      width: 12px; height: 12px; border-radius: 50%;
      background: var(--brown-light); border: 2px solid var(--white);
    }
    .timeline-date {
      font-size: 0.75rem; color: var(--brown-light);
      letter-spacing: 0.08em; text-transform: uppercase;
      font-weight: 500; margin-bottom: 0.3rem;
    }
    .timeline-role {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem; font-weight: 600;
      color: var(--espresso); margin-bottom: 0.15rem;
    }
    .timeline-company {
      font-size: 0.85rem; color: var(--brown);
      font-weight: 500; margin-bottom: 0.8rem;
    }
    .timeline-list { list-style: none; }
    .timeline-list li {
      font-size: 0.88rem; color: var(--text-muted);
      line-height: 1.75; padding-left: 1rem; position: relative;
      margin-bottom: 0.4rem;
    }
    .timeline-list li::before {
      content: '→'; position: absolute; left: 0;
      color: var(--brown-light); font-size: 0.8rem;
    }

    /* EDUCATION */
    #education { background: var(--cream); }
    .edu-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: 1rem; }
    .edu-card {
      background: var(--white); border-radius: 10px;
      padding: 1.2rem 1.4rem;
      border: 1px solid var(--cream-dark);
      transition: all 0.2s;
    }
    .edu-card:hover { transform: translateY(-3px); box-shadow: 0 8px 24px rgba(139,99,64,0.12); }
    .edu-card .year {
      font-size: 0.72rem; color: var(--brown-light);
      letter-spacing: 0.1em; text-transform: uppercase; margin-bottom: 0.4rem;
    }
    .edu-card .degree {
      font-weight: 600; font-size: 0.88rem;
      color: var(--brown-dark); margin-bottom: 0.2rem;
    }
    .edu-card .institution {
      font-size: 0.78rem; color: var(--text-muted);
    }

    /* CONTACT */
    #contact { background: var(--espresso); }
    #contact .section-label { color: var(--brown-light); }
    #contact .section-title { color: var(--white); }
    .contact-grid {
      display: grid; grid-template-columns: 1fr 1fr; gap: 2rem; align-items: start;
    }
    .contact-text {
      font-size: 0.95rem; color: rgba(255,255,255,0.6);
      line-height: 1.8;
    }
    .contact-links { display: flex; flex-direction: column; gap: 0.9rem; }
    .contact-link {
      display: flex; align-items: center; gap: 0.8rem;
      text-decoration: none; padding: 0.9rem 1.2rem;
      background: rgba(255,255,255,0.06);
      border: 1px solid rgba(255,255,255,0.1);
      border-radius: 8px; transition: all 0.2s;
      color: rgba(255,255,255,0.85); font-size: 0.85rem;
    }
    .contact-link:hover { background: rgba(255,255,255,0.12); border-color: var(--brown-light); }
    .contact-icon { font-size: 1.1rem; }

    /* FOOTER */
    footer {
      background: var(--espresso);
      border-top: 1px solid rgba(255,255,255,0.06);
      padding: 1.5rem 2rem;
      text-align: center;
      font-size: 0.78rem;
      color: rgba(255,255,255,0.3);
    }

    /* ANIMATIONS */
    @keyframes fadeUp {
      from { opacity: 0; transform: translateY(28px); }
      to { opacity: 1; transform: translateY(0); }
    }
    .reveal { opacity: 0; transform: translateY(28px); transition: opacity 0.7s ease, transform 0.7s ease; }
    .reveal.visible { opacity: 1; transform: translateY(0); }

    /* RESPONSIVE */
    @media (max-width: 680px) {
      .nav-links { display: none; }
      .about-grid, .contact-grid { grid-template-columns: 1fr; }
      .hero-stats { gap: 1.5rem; }
    }
  </style>
</head>
